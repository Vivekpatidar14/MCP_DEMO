# Copy to .env.local and fill in values. For CI builds without secrets:
# SKIP_ENV_VALIDATION=1

SKIP_ENV_VALIDATION=

# Atlassian Rovo MCP (https://mcp.atlassian.com/v1/mcp) — use a Rovo MCP scoped API token when required by your org
JIRA_API_TOKEN=
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_USER_EMAIL=you@company.com

# Optional: stable cloud UUID for Jira MCP tools (skips discovery tool calls)
# JIRA_CLOUD_ID=

# Optional: override MCP tool names if your Atlassian server version differs
# JIRA_MCP_TOOL_CLOUD_DISCOVERY=
# JIRA_MCP_TOOL_GET_ISSUE=
# JIRA_MCP_TOOL_LIST_PROJECTS=
# JIRA_MCP_TOOL_ADD_COMMENT=

# GitHub remote MCP (https://api.githubcopilot.com/mcp/) — PAT with repo + PR scopes
GITHUB_PAT=
GITHUB_DEFAULT_OWNER=your-github-username-or-org

# Optional overrides
# JIRA_MCP_URL=https://mcp.atlassian.com/v1/mcp
# GITHUB_MCP_URL=https://api.githubcopilot.com/mcp/
# GITHUB_MCP_TOOL_SEARCH_REPOS=search_repositories
# GITHUB_MCP_TOOL_CREATE_BRANCH=create_branch
# GITHUB_MCP_TOOL_CREATE_PR=create_pull_request
# GITHUB_MCP_TOOL_ISSUE_WRITE=issue_write
